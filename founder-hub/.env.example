FOUNDER_HUB_ANALYTICS_TOKEN=

FOUNDER_HUB_SECRET=
FOUNDER_HUB_ALLOW_REMOTE=false
NEXT_PUBLIC_BASE_URL=http://127.0.0.1:3030
